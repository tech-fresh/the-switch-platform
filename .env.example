# The Switch Platform Mark 3.2
# Copy this file to `.env.local` for local development or adapt it for your deployed environment.
#
# Final Path Mark 2 live auth minimum:
# - SWITCH_AUTH_MODE=oidc
# - SWITCH_AUTH_SECRET=<long random secret>
# - SWITCH_AUTH_BASE_URL=<deployed app origin>
# - one full OIDC provider block with client id, client secret, authorization url,
#   token url, and user-info url

# Auth runtime
# preview-cookie = local preview sign-in
# oidc = redirect-based live sign-in
# external-header = trusted upstream identity layer
SWITCH_AUTH_MODE=preview-cookie

# Required for oidc and external-header. Optional in preview-cookie because the preview fallback exists.
SWITCH_AUTH_SECRET=replace-with-a-long-random-secret

# Used for redirect-based auth flows in deployed environments.
SWITCH_AUTH_BASE_URL=http://localhost:3000

# Only required when SWITCH_AUTH_MODE=external-header.
SWITCH_EXTERNAL_AUTH_HEADER_SECRET=replace-with-shared-header-secret

# Optional auth session tuning.
SWITCH_AUTH_SESSION_TTL_SECONDS=43200
SWITCH_AUTH_FLOW_TTL_SECONDS=600

# Optional role mapping for authenticated users.
SWITCH_AUTH_EDITOR_EMAILS=editor@example.com
SWITCH_AUTH_ADMIN_EMAILS=admin@example.com

# OIDC provider configuration
# Configure one or more full provider blocks when SWITCH_AUTH_MODE=oidc.

# Email magic link provider
SWITCH_OIDC_EMAIL_MAGIC_LINK_CLIENT_ID=
SWITCH_OIDC_EMAIL_MAGIC_LINK_CLIENT_SECRET=
SWITCH_OIDC_EMAIL_MAGIC_LINK_AUTHORIZATION_URL=
SWITCH_OIDC_EMAIL_MAGIC_LINK_TOKEN_URL=
SWITCH_OIDC_EMAIL_MAGIC_LINK_USERINFO_URL=
SWITCH_OIDC_EMAIL_MAGIC_LINK_SCOPES=openid profile email
SWITCH_OIDC_EMAIL_MAGIC_LINK_PROMPT=

# Google provider
SWITCH_OIDC_GOOGLE_CLIENT_ID=
SWITCH_OIDC_GOOGLE_CLIENT_SECRET=
SWITCH_OIDC_GOOGLE_AUTHORIZATION_URL=
SWITCH_OIDC_GOOGLE_TOKEN_URL=
SWITCH_OIDC_GOOGLE_USERINFO_URL=
SWITCH_OIDC_GOOGLE_SCOPES=openid profile email
SWITCH_OIDC_GOOGLE_PROMPT=

# Apple provider
SWITCH_OIDC_APPLE_CLIENT_ID=
SWITCH_OIDC_APPLE_CLIENT_SECRET=
SWITCH_OIDC_APPLE_AUTHORIZATION_URL=
SWITCH_OIDC_APPLE_TOKEN_URL=
SWITCH_OIDC_APPLE_USERINFO_URL=
SWITCH_OIDC_APPLE_SCOPES=openid profile email
SWITCH_OIDC_APPLE_PROMPT=

# Final Path Mark 2 live OIDC release example
# Use exactly one complete provider block at minimum before running the live launch sequence.
# Replace every example value below with the real deployed identity-provider values.
#
# SWITCH_AUTH_MODE=oidc
# SWITCH_AUTH_SECRET=replace-with-a-long-random-production-secret
# SWITCH_AUTH_BASE_URL=https://app.switch.example.com
#
# SWITCH_OIDC_GOOGLE_CLIENT_ID=google-client-id
# SWITCH_OIDC_GOOGLE_CLIENT_SECRET=google-client-secret
# SWITCH_OIDC_GOOGLE_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
# SWITCH_OIDC_GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
# SWITCH_OIDC_GOOGLE_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
# SWITCH_OIDC_GOOGLE_SCOPES=openid profile email
# SWITCH_OIDC_GOOGLE_PROMPT=select_account

# Persistence runtime
# local-json = provisional local files
# sqlite = intended shared live path in the current codebase
# memory = preview-only reset-on-restart mode
SWITCH_PERSISTENCE_DRIVER=local-json

# Explicit data directory is required for the intended live persistence path.
SWITCH_DATA_DIRECTORY=

# CMS runtime
# live = writable workflow path
# read-only = locked editorial runtime
SWITCH_CMS_BACKEND_MODE=live

# Optional live verification target used by `npm run verify:live-readiness`.
SWITCH_LIVE_BASE_URL=

# Optional live route walkthrough credentials used by `npm run verify:live-walkthrough`.
# For oidc or cookie-backed live auth, provide raw cookie header values.
SWITCH_LIVE_STUDENT_COOKIE=
SWITCH_LIVE_ADMIN_COOKIE=

# For external-header live auth, provide the identity values used to build trusted headers.
SWITCH_LIVE_STUDENT_USER_ID=
SWITCH_LIVE_STUDENT_DISPLAY_NAME=
SWITCH_LIVE_STUDENT_EMAIL=
SWITCH_LIVE_STUDENT_ROLES=student
SWITCH_LIVE_STUDENT_PROVIDER=google
SWITCH_LIVE_STUDENT_YEAR_GROUP=Year 11
SWITCH_LIVE_STUDENT_TARGET_QUALIFICATIONS=GCSE
SWITCH_LIVE_STUDENT_SESSION_ID=
SWITCH_LIVE_STUDENT_SIGNED_IN_AT=
SWITCH_LIVE_STUDENT_EXPIRES_AT=

SWITCH_LIVE_ADMIN_USER_ID=
SWITCH_LIVE_ADMIN_DISPLAY_NAME=
SWITCH_LIVE_ADMIN_EMAIL=
SWITCH_LIVE_ADMIN_ROLES=admin
SWITCH_LIVE_ADMIN_PROVIDER=google
SWITCH_LIVE_ADMIN_YEAR_GROUP=Operations
SWITCH_LIVE_ADMIN_TARGET_QUALIFICATIONS=GCSE
SWITCH_LIVE_ADMIN_SESSION_ID=
SWITCH_LIVE_ADMIN_SIGNED_IN_AT=
SWITCH_LIVE_ADMIN_EXPIRES_AT=

# Optional launch-governance recording for verification scripts.
# Set SWITCH_RECORD_GOVERNANCE=1 when you want `verify:release`, `verify:live-readiness`,
# `test:final-smoke`, `verify:live-walkthrough`, or `verify:launch-signoff` to write governance records for the named environment.
SWITCH_RECORD_GOVERNANCE=0
SWITCH_GOVERNANCE_ENVIRONMENT=
SWITCH_GOVERNANCE_EVIDENCE_OWNER=
SWITCH_GOVERNANCE_SMOKE_OWNER=
SWITCH_GOVERNANCE_ENVIRONMENT_OWNER=

# Optional final trust and release sign-off inputs used by `npm run verify:launch-signoff`.
SWITCH_LAUNCH_APPROVER=
SWITCH_LAUNCH_STOP_AUTHORITY=
SWITCH_GOVERNANCE_PRIVACY_REVIEW_OWNER=
SWITCH_GOVERNANCE_SAFEGUARDING_REVIEW_OWNER=
SWITCH_GOVERNANCE_RELEASE_REVIEW_OWNER=
SWITCH_GOVERNANCE_PRIVACY_SIGNOFF_OWNER=
SWITCH_GOVERNANCE_SAFEGUARDING_SIGNOFF_OWNER=
SWITCH_GOVERNANCE_ALERTS_SIGNOFF_OWNER=
SWITCH_GOVERNANCE_INCIDENT_SIGNOFF_OWNER=
SWITCH_GOVERNANCE_RELEASE_SIGNOFF_OWNER=
SWITCH_GOVERNANCE_PRIVACY_REVIEW_NOTE=
SWITCH_GOVERNANCE_SAFEGUARDING_REVIEW_NOTE=
SWITCH_GOVERNANCE_RELEASE_REVIEW_NOTE=
SWITCH_GOVERNANCE_PRIVACY_SIGNOFF_NOTE=
SWITCH_GOVERNANCE_SAFEGUARDING_SIGNOFF_NOTE=
SWITCH_GOVERNANCE_ALERTS_SIGNOFF_NOTE=
SWITCH_GOVERNANCE_INCIDENT_SIGNOFF_NOTE=
SWITCH_GOVERNANCE_RELEASE_SIGNOFF_NOTE=

# Optional dry-run helper for the final orchestration command.
SWITCH_LAUNCH_COMPLETE_DRY_RUN=0
