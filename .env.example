SWITCH_AUTH_SECRET=replace-with-a-long-random-secret
SWITCH_AUTH_BASE_URL=https://your-live-switch-domain.example

# One complete live OIDC provider block.
SWITCH_AUTH_OIDC_PROVIDER_ID=switch-live-oidc
SWITCH_AUTH_OIDC_PROVIDER_NAME=Live OIDC
SWITCH_AUTH_OIDC_ISSUER_URL=https://issuer.example.com
SWITCH_AUTH_OIDC_CLIENT_ID=replace-with-live-client-id
SWITCH_AUTH_OIDC_CLIENT_SECRET=replace-with-live-client-secret
SWITCH_AUTH_OIDC_SCOPES=openid profile email
