# Free-tier Fly.io deploy — copy to a local secrets file, fill values, then:
#   fly secrets import < path/to/your-secrets.env
#
# Full guide: docs/FREE_TIER_DEPLOY.md

# Replace with your Fly app URL after fly launch
SWITCH_AUTH_BASE_URL=https://the-switch-platform.fly.dev
SWITCH_LIVE_BASE_URL=https://the-switch-platform.fly.dev

# Persistence — set in fly.toml too; secrets override if duplicated
SWITCH_PERSISTENCE_DRIVER=sqlite
SWITCH_DATA_DIRECTORY=/data
SWITCH_CMS_BACKEND_MODE=live
SWITCH_AUTO_BOOTSTRAP_SQLITE=1

# Auth (copy from Vercel or your IdP)
SWITCH_AUTH_MODE=oidc
SWITCH_AUTH_SECRET=replace-with-long-random-secret

SWITCH_OIDC_GOOGLE_CLIENT_ID=
SWITCH_OIDC_GOOGLE_CLIENT_SECRET=
SWITCH_OIDC_GOOGLE_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
SWITCH_OIDC_GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
SWITCH_OIDC_GOOGLE_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
SWITCH_OIDC_GOOGLE_SCOPES=openid profile email

# Live verification (your machine — not Fly secrets unless you run checks on Fly)
SWITCH_LIVE_STUDENT_COOKIE=
SWITCH_LIVE_ADMIN_COOKIE=

# Governance / launch sign-off (for verify:launch-complete)
SWITCH_RECORD_GOVERNANCE=1
SWITCH_GOVERNANCE_ENVIRONMENT=fly-production
SWITCH_LAUNCH_APPROVER=
SWITCH_LAUNCH_STOP_AUTHORITY=
SWITCH_GOVERNANCE_PRIVACY_REVIEW_NOTE=Reviewed for Fly production cutover.
SWITCH_GOVERNANCE_SAFEGUARDING_REVIEW_NOTE=Reviewed for Fly production cutover.
SWITCH_GOVERNANCE_RELEASE_REVIEW_NOTE=Reviewed for Fly production cutover.
SWITCH_GOVERNANCE_PRIVACY_SIGNOFF_NOTE=Signed off for Fly production cutover.
SWITCH_GOVERNANCE_SAFEGUARDING_SIGNOFF_NOTE=Signed off for Fly production cutover.
SWITCH_GOVERNANCE_ALERTS_SIGNOFF_NOTE=Signed off for Fly production cutover.
SWITCH_GOVERNANCE_INCIDENT_SIGNOFF_NOTE=Signed off for Fly production cutover.
SWITCH_GOVERNANCE_RELEASE_SIGNOFF_NOTE=Signed off for Fly production cutover.
