{
  "name": "the-switch-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "node scripts/repo-lint.mjs",
    "type-check": "tsc --noEmit",
    "test": "tsx --test tests/*.test.mjs",
    "test:smoke": "node scripts/route-smoke.mjs",
    "test:e2e": "node scripts/launch-e2e.mjs",
    "test:final-smoke": "node scripts/final-live-smoke.mjs",
    "verify:release": "node scripts/release-verify.mjs",
    "verify:live-readiness": "node scripts/live-readiness.mjs",
    "verify:launch-status": "node scripts/launch-status.mjs",
    "verify:live-walkthrough": "node scripts/live-route-walkthrough.mjs",
    "verify:live-onboarding": "node scripts/verify-live-onboarding.mjs",
    "verify:live-truth-match": "node scripts/live-truth-match.mjs",
    "verify:launch-signoff": "node scripts/launch-signoff.mjs",
    "verify:launch-complete": "node scripts/launch-complete.mjs",
    "verify:persistence-recovery": "node scripts/persistence-recovery-check.mjs",
    "verify:blob-health": "node scripts/verify-blob-health.mjs",
    "verify:persistence-health": "node scripts/verify-persistence-health.mjs",
    "verify:google-oauth-live": "node scripts/verify-google-oauth-live.mjs",
    "setup:google-oauth-live": "bash scripts/setup-google-oauth-live.sh",
    "verify:microsoft-oauth-live": "node scripts/verify-microsoft-oauth-live.mjs",
    "setup:microsoft-oauth-live": "bash scripts/setup-microsoft-oauth-live.sh",
    "provision:microsoft-oauth-live": "bash scripts/provision-microsoft-oauth-live.sh",
    "provision:microsoft-oauth-live:apply": "SKIP_AZ_LOGIN=1 bash scripts/provision-microsoft-oauth-live.sh",
    "apply:microsoft-oauth-azure-free": "bash scripts/apply-microsoft-oauth-azure-free.sh",
    "patch:google-oauth-client": "bash scripts/patch-google-oauth-client.sh",
    "install:gcloud-macos": "bash scripts/install-gcloud-macos.sh",
    "persistence:migrate-to-sqlite": "node scripts/persistence-migrate-to-sqlite.mjs",
    "persistence:restore-from-backup": "node scripts/persistence-restore-from-backup.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.1",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.5",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.5",
    "@storybook/nextjs-vite": "^10.4.5",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.21",
    "mockdate": "^3.0.5",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "playwright": "^1.61.0",
    "postcss": "^8.5.4",
    "storybook": "^10.4.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
